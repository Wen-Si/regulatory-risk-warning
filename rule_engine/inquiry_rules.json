    "financial_signals": {
      "name": "财务异常信号",
      "description": "触发问询的财务指标异常",
      "rules": [
        {"id": "FS001", "signal": "商誉占净资产>25%", "weight": 15, "type": "商誉减值风险", "regex_check": "goodwill_ratio > 25"},
        {"id": "FS002", "signal": "并购标的业绩承诺未达标", "weight": 12, "type": "商誉减值"},
        {"id": "FS003", "signal": "资产负债率>65%", "weight": 15, "type": "偿债压力"},
        {"id": "FS004", "signal": "经营现金流/净利润<0.5", "weight": 13, "type": "盈利质量存疑"},
        {"id": "FS005", "signal": "应收账款周转率<3", "weight": 12, "type": "回款风险"},
        {"id": "FS006", "signal": "存货周转率<2", "weight": 10, "type": "存货积压/减值风险"},
        {"id": "FS007", "signal": "营收增长率异常（绝对值>50%或为负）", "weight": 10, "type": "经营波动"},
        {"id": "FS008", "signal": "净利润与营收背离", "weight": 13, "type": "财务真实性"},
        {"id": "FS009", "signal": "毛利率异常波动", "weight": 10, "type": "财务真实性"},
        {"id": "FS010", "signal": "前五大客户/供应商集中度过高", "weight": 10, "type": "客户依赖/供应商依赖"},
        {"id": "FS011", "signal": "其他应收/应付异常增长", "weight": 12, "type": "资金占用嫌疑"},
        {"id": "FS012", "signal": "研发支出资本化率异常", "weight": 8, "type": "会计估计"},
        {"id": "FS013", "signal": "在建工程长期挂账", "weight": 8, "type": "资产真实性"},
        {"id": "FS014", "signal": "营业收入扣除金额大", "weight": 10, "type": "收入合规性"},
        {"id": "FS015", "signal": "第四季度收入占比异常", "weight": 9, "type": "收入确认时点"}
