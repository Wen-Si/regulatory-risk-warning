    "structural_patterns": {
      "name": "问询函结构规律",
      "description": "问询函的标准结构和问询模式",
      "rules": [
        {
          "id": "SP001",
          "pattern": "引言段",
          "template": "Y年M月D日，你公司公告称{触发事项}。鉴于上述事项对投资者影响重大，根据本所《股票上市规则》第13.1.1条等有关规定，现请你公司核实并披露如下事项。",
          "weight": 1.0
        },
        {
          "id": "SP002",
          "pattern": "问询主体",
          "template": "一、关于{主题1}：请公司补充披露：(1){问题1};(2){问题2};(3){问题3}。",
          "weight": 1.0
        },
        {
          "id": "SP003",
          "pattern": "问询主体-投资类",
          "template": "请公司补充披露：(1)交易作价公允性及估值依据；(2)交易对方背景及关联关系；(3)交易对公司持续经营的影响；(4)资金来源及支付安排。",
          "weight": 0.85
        },
        {
          "id": "SP004",
          "pattern": "问询主体-财务类",
          "template": "请公司补充披露：(1)收入确认政策及依据；(2)前N大客户/供应商详情；(3)应收账款账龄及坏账准备；(4)是否具有商业实质。",
          "weight": 0.90
        },
        {
          "id": "SP005",
          "pattern": "问询主体-合规类",
          "template": "请公司补充披露：(1)内幕信息知情人登记情况；(2)自查相关信息是否提前泄露；(3)实控人/董监高近期股票交易情况。",
          "weight": 0.80
        },
        {
          "id": "SP006",
          "pattern": "收尾要求",
          "template": "请公司收到本问询函后立即披露，并于5个交易日内披露对本问询函的回复。请{律师/独立董事/年审会计师}发表意见。",
          "weight": 1.0
        }
      ]
    },
