    "inquiry_time_window": {
      "name": "问询时间窗口",
      "rules": [
        {"type": "年报问询函", "trigger": "年报披露后30-90天内", "weight": 0.95},
        {"type": "重组预案问询函", "trigger": "公告后10-30天内", "weight": 0.90},
        {"type": "日常问询函", "trigger": "公告后5-15天内", "weight": 0.75},
        {"type": "关注函", "trigger": "事件发生当日", "weight": 0.85}
      ]
    },
    "common_question_library": {
      "name": "常见问询问题库",
      "description": "高频出现的问询问题模板",
      "questions": [
        "请公司结合{财务指标}说明是否存在异常，并说明原因",
        "请公司补充披露{交易对方}的基本情况及与公司是否存在关联关系",
        "请公司说明{事项}对持续经营能力的影响，并充分提示风险",
        "请公司自查{事项}的信息披露是否真实、准确、完整",
        "请公司结合{事项}说明是否存在利用信息披露配合{股东减持/市值管理}的情形",
        "请公司说明内幕信息知情人登记及保密措施执行情况",
        "请公司说明交易作价的公允性及估值依据",
        "请公司说明{业务}的商业实质及收入确认合规性",
        "请年审会计师对{财务事项}发表意见",
        "请独立董事对{重大事项}发表意见",
        "请律师对{合规事项}发表意见"
      ]
    }
  },
