      "name": "触发事件类型",
      "description": "容易触发监管问询的公告事件类型",
      "rules": [
        {
          "id": "TR001",
          "type": "重大资产重组",
          "weight": 35,
          "keywords": ["重大资产购买报告书", "发行股份及支付现金购买资产", "重大资产重组草案", "重大资产重组预案"],
          "sample_companies": ["永杰新材", "威帝股份", "韩建河山", "明阳智能", "得邦照明"],
          "common_questions": ["交易方案是否合理", "标的资产财务状况", "估值依据及评估方法", "业绩承诺合理性", "整合风险"],
          "trigger_probability": 0.90
        },
        {
          "id": "TR002",
          "type": "资产收购/股权收购",
